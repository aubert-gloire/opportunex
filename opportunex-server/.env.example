PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/opportunex

# JWT
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRE=7d

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Email (Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_FROM=noreply@opportunex.com

# Frontend URL
CLIENT_URL=http://localhost:5173

# Flutterwave Payment (flutterwave.com → Dashboard → API Keys)
# Leave as-is to use simulated payments in development
FLUTTERWAVE_PUBLIC_KEY=your_flw_public_key
FLUTTERWAVE_SECRET_KEY=your_flw_secret_key
FLUTTERWAVE_ENCRYPTION_KEY=your_flw_encryption_key
# Webhook hash: Flutterwave Dashboard → Webhooks → Secret Hash
FLUTTERWAVE_SECRET_HASH=your_flw_secret_hash

# Admin Default
ADMIN_EMAIL=admin@opportunex.com
ADMIN_PASSWORD=Admin@123456

# ── Free API Integrations ─────────────────────────────────────────────────────

# Google Gemini AI (Free: 15 RPM, 1M tokens/day)
# Get key: aistudio.google.com → Get API Key
GEMINI_API_KEY=your_gemini_api_key

# Africa's Talking SMS (Free sandbox, live for Rwanda +250 numbers)
# Get key: africastalking.com → Register → My Apps → Create App
# Use AT_USERNAME=sandbox for development
AT_USERNAME=sandbox
AT_API_KEY=your_africastalking_api_key

# YouTube Data API v3 (Free: 10,000 units/day)
# Get key: console.cloud.google.com → Enable YouTube Data API v3 → Create credentials
YOUTUBE_API_KEY=your_youtube_api_key

# ExchangeRate API — NO KEY NEEDED (open.er-api.com, 1,500 free req/month)
# Used automatically for RWF ↔ USD salary conversion

# RemoteOK + Jobicy — NO KEY NEEDED (free remote job boards)
# Used automatically in /api/external/jobs
